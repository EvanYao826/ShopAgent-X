## This file must *NOT* be checked into Version Control Systems,
# as it contains information specific to your local configuration.
#
# Location of the SDK. This is only used by Gradle.
# For customization when using a Version Control System, please read the
# header note.

# 复制此文件为 local.properties，然后修改下面的路径为你的 Android SDK 路径
# Windows 示例：
# sdk.dir=C\\:\\\\Users\\\\YourUsername\\\\AppData\\\\Local\\\\Android\\\\Sdk

# sdk.dir=/path/to/your/android/sdk

# Release 签名配置（可选）
# 生成 keystore: keytool -genkey -v -keystore release.keystore -alias shopagent -keyalg RSA -keysize 2048 -validity 10000
# keystore.storeFile=release.keystore
# keystore.storePassword=your_store_password
# keystore.keyAlias=shopagent
# keystore.keyPassword=your_key_password
